# ──────────────────────────────────────────────────────
# Environment configuration for playwright-amazon-cloudeagle
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────

# Base URL of the Amazon store under test.
# Change this to test a different regional store.
BASE_URL=https://www.amazon.in

# Set to "true" to run browsers in headless mode locally.
# On CI this is always forced to true regardless of this value.
HEADLESS=false
